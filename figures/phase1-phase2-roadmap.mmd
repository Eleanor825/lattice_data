flowchart TB
    subgraph SRC["Data Sources"]
        S1["Scholarly Sources<br/>OpenAlex · Crossref · arXiv · Europe PMC"]
        S2["Materials Sources<br/>Materials Project · OQMD · NOMAD · JARVIS · Materials Cloud"]
        S3["Chemistry and Knowledge<br/>PubChem · Wikidata · NIST · ORD · Catalysis data"]
    end

    subgraph P1["Phase 1 · Data Foundation"]
        P11["Source Registry and Connectors<br/>source catalog · auth gating · fetch adapters"]
        P12["Ingestion Layer<br/>API fetch · dumps · web pages · files"]
        P13["Schema Normalization<br/>Document · StructuredRecord · KnowledgeRecord · InstructionTrace"]
        P14["Quality and Traceability<br/>provenance · license · dedup · filtering · lineage"]
        P15["Compiled Views<br/>pretrain · qa · instruction · knowledge"]
        P16["Release Artifacts<br/>manifest · dataset card · workflow spec"]
        P11 --> P12 --> P13 --> P14 --> P15 --> P16
    end

    subgraph CTRL["Platform Control Plane"]
        C1["Registry and API<br/>runs · datasets · backends · rerun"]
        C2["Workflow Runtime<br/>save spec · replay spec · migrate engines"]
        C3["Product Surface<br/>CLI today · chat and drag-and-drop next"]
        C1 --- C2 --- C3
    end

    subgraph P2["Phase 2 · Training and Optimization"]
        P21["Engine-Portable Preparation<br/>pandas · Spark · Flink"]
        P22["Training Workflows<br/>pretrain · continue · finetune · posttrain"]
        P23["Model Backends<br/>local tiny · Hugging Face open models · external closed connectors"]
        P24["Run Outputs<br/>checkpoints · metrics · manifests"]
        P21 --> P22 --> P24
        P23 --> P22
    end

    subgraph OUT["Deliverables"]
        O1["Reusable Data Assets"]
        O2["Improved Models"]
        O3["Traceable Reproduction"]
    end

    S1 --> P12
    S2 --> P12
    S3 --> P12

    P16 --> O1
    P15 --> P21
    P16 -. release metadata .-> C1
    C2 -. replay or migrate .-> P21
    C1 -. submit and track .-> P22
    C3 -. operator control .-> C1
    P24 --> O2
    P16 --> O3
    P24 --> O3

    classDef source fill:#FFF7ED,stroke:#EA580C,color:#7C2D12,stroke-width:1.5px;
    classDef phase1 fill:#EFF6FF,stroke:#2563EB,color:#1E3A8A,stroke-width:1.5px;
    classDef control fill:#F5F3FF,stroke:#7C3AED,color:#4C1D95,stroke-width:1.5px;
    classDef phase2 fill:#ECFDF5,stroke:#059669,color:#065F46,stroke-width:1.5px;
    classDef out fill:#F8FAFC,stroke:#475569,color:#0F172A,stroke-width:1.5px;

    class S1,S2,S3 source;
    class P11,P12,P13,P14,P15,P16 phase1;
    class C1,C2,C3 control;
    class P21,P22,P23,P24 phase2;
    class O1,O2,O3 out;
